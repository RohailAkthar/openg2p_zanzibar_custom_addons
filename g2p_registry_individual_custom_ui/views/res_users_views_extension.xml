<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Redesign the Change Password Wizard Form to use a vertical single-user layout -->
    <record id="change_password_wizard_view_inherit" model="ir.ui.view">
        <field name="name">change.password.wizard.form.inherit</field>
        <field name="model">change.password.wizard</field>
        <field name="inherit_id" ref="base.change_password_wizard_view"/>
        <field name="arch" type="xml">
            <!-- Hide the standard multi-user table when single user display is active -->
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="invisible">user_id_display</attribute>
            </xpath>
            <!-- Add the clean vertical fields for single-user edit -->
            <xpath expr="//field[@name='user_ids']" position="before">
                <group invisible="not user_id_display">
                    <field name="user_id_display"/>
                    <field name="user_login_display"/>
                    <field name="new_passwd_display" password="True" default_focus="1" style="width: 250px;"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Restrict "Change Password" action to only appear in the Form view (single user) -->
    <record id="base.change_password_wizard_action" model="ir.actions.act_window">
        <field name="binding_view_types">form</field>
    </record>
</odoo>
