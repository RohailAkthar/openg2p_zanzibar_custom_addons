<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_individuals_form_custom" model="ir.ui.view">
        <field name="name">view_individuals_form_custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_individual.view_individuals_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <!-- Keep create="1" to enable Import, but we'll hide the New button via CSS -->
                <attribute name="class">hide_new_button_form</attribute>
            </xpath>
            <!-- Extend width of family_name -->
            <xpath expr="//field[@name='family_name']" position="attributes">
                <attribute name="style">width:250px</attribute>
            </xpath>

            <!-- Extend width of given_name -->
            <xpath expr="//field[@name='given_name']" position="attributes">
                <attribute name="style">width:250px</attribute>
            </xpath>

            <!-- Extend width of middle_name -->
            <xpath expr="//field[@name='middle_name']" position="attributes">
                <attribute name="style">width:250px</attribute>
            </xpath>

            <!-- Make Pensioner ID Readonly -->
            <xpath expr="//field[@name='pensioner_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_individuals_tree_custom" model="ir.ui.view">
        <field name="name">view_individuals_tree_custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_individual.view_individuals_list_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">hide_new_button_tree</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="before">
                <field name="pensioner_id" />
                <field name="benf_zan_id" />
            </xpath>
        </field>
    </record>
    <record id="view_enumerator_config_tree_custom" model="ir.ui.view">
        <field name="name">view_enumerator_config_tree_custom</field>
        <field name="model">g2p.enumerator</field>
        <field name="inherit_id" ref="g2p_enumerator.view_enumerator_config_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">hide_new_button_tree</attribute>
            </xpath>
            <xpath expr="//field[@name='enum_latitude']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='enum_longitude']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='enum_altitude']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='enum_accuracy']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_enumerator_config_form_custom" model="ir.ui.view">
        <field name="name">view_enumerator_config_form_custom</field>
        <field name="model">g2p.enumerator</field>
        <field name="inherit_id" ref="g2p_enumerator.view_enumerator_config_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="class">hide_new_button_form</attribute>
            </xpath>
            <xpath expr="//field[@name='enum_latitude']/.." position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
