<odoo>
    <!-- Override existing groups from g2p_draft_publish -->
    
    <record id="g2p_draft_publish.group_int_validator" model="res.groups">
        <field name="name">Viewer</field>
    </record>

    <record id="g2p_draft_publish.group_int_approver" model="res.groups">
        <field name="name">Approver</field>
        <!-- Ensure it still implies Viewer -->
        <field name="implied_ids" eval="[(4, ref('g2p_draft_publish.group_int_validator'))]"/>
    </record>

    <record id="g2p_draft_publish.group_int_admin" model="res.groups">
        <field name="category_id" eval="False"/>
    </record>

    <!-- Record Rules Overrides to allow viewing ALL records -->
    <record id="g2p_draft_publish.g2p_draft_record_following_restriction_rule" model="ir.rule">
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(6, 0, [ref('g2p_draft_publish.group_int_validator'), ref('g2p_draft_publish.group_int_approver')])]"/>
    </record>

    <record id="g2p_draft_publish.g2p_submitted_validator_record_following_restriction_rule_validator" model="ir.rule">
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(6, 0, [ref('g2p_draft_publish.group_int_validator')])]"/>
    </record>
</odoo>
