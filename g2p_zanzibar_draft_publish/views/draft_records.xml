<odoo>
    <!-- Inherit Tree View -->
    <record id="view_draft_imported_record_tree_inherit" model="ir.ui.view">
        <field name="name">draft.record.tree.inherit</field>
        <field name="model">draft.record</field>
        <field name="inherit_id" ref="g2p_draft_publish.view_draft_imported_record_tree" />
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="create">0</attribute>
                <attribute name="import">0</attribute>
            </xpath>
            <!-- Hide original fields properly using column_invisible for Odoo 17 -->
            <xpath expr="//field[@name='given_name']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='family_name']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='addl_name']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='region']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>

            <!-- Add and position new fields -->
            <xpath expr="//field[@name='given_name']" position="before">
                <field name="zan_id" readonly="id != False" />
                <field name="name" readonly="id != False" />
            </xpath>

            <xpath expr="//field[@name='gender']" position="after">
                <field name="birthdate_date" readonly="id != False" />
                <field name="registration_date" readonly="id != False" />
            </xpath>

            <!-- Hide Submit button -->
            <xpath expr="//button[@name='action_submit']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Show Approve button for draft state instead of submitted -->
            <xpath expr="//button[@name='action_publish']" position="attributes">
                <attribute name="invisible">state != 'draft'</attribute>
            </xpath>

            <!-- Show Reject button for draft state instead of submitted -->
            <xpath expr="//button[@name='action_reject']" position="attributes">
                <attribute name="invisible">state != 'draft'</attribute>
            </xpath>

            <!-- Fix State column alignment and colors -->
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="decoration-success">state == 'published'</attribute>
                <attribute name="decoration-info">state == 'draft'</attribute>
                <attribute name="widget">badge</attribute>
                <attribute name="class">text-start</attribute>
            </xpath>

            <!-- Changed from Edit to View and set to readonly action -->
            <xpath expr="//button[@name='action_open_wizard']" position="attributes">
                <attribute name="name">action_open_wizard_view_only</attribute>
                <attribute name="string">View</attribute>
                <attribute name="invisible">state != 'draft'</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit Form View -->
    <record id="view_draft_imported_record_form_inherit" model="ir.ui.view">
        <field name="name">draft.record.form.inherit.zanzibar</field>
        <field name="model">draft.record</field>
        <field name="inherit_id" ref="g2p_draft_publish.view_draft_imported_record_form" />
        <field name="arch" type="xml">
            <!-- Ensure statusbar matches new model state names if needed, otherwise use original -->
            <xpath expr="//header" position="replace">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published" />
                </header>
            </xpath>
            
            <xpath expr="//sheet" position="replace">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Registrant Name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="given_name" readonly="1"/>
                            <field name="middle_name" readonly="1"/>
                            <field name="family_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="zan_id" readonly="1"/>
                            <field name="birthdate_date" string="Date of Birth" readonly="1"/>
                            <field name="registration_date" readonly="1"/>
                            <field name="gender" readonly="1"/>
                            <field name="phone" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Personal Info" name="personal_info">
                            <group>
                                <group>
                                    <field name="address_display" string="Address" readonly="1"/>
                                    <field name="post_code" string="Post Code" readonly="1"/>
                                    <field name="region_id" string="Region" readonly="1"/>
                                    <field name="district_id" readonly="1"/>
                                    <field name="birthdate_date" string="Date of Birth" readonly="1"/>
                                    <field name="age" readonly="1" />
                                    <field name="gender" readonly="1"/>
                                </group>
                                <group>
                                    <group string="Phone Numbers">
                                        <field name="phone" nolabel="1" readonly="1"/>
                                    </group>
                                    <group string="Additional Information">
                                        <field name="has_disability" widget="radio" options="{'horizontal': true}" readonly="1"/>
                                        <field name="receives_allowance" widget="radio" options="{'horizontal': true}" readonly="1"/>
                                        <field name="has_health_insurance" widget="radio" options="{'horizontal': true}" readonly="1"/>
                                    </group>
                                </group>
                            </group>
                        </page>
                        <page string="Nominee Info" name="nominee_info">
                            <group>
                                <group>
                                    <field name="nominee_first_name" readonly="1"/>
                                    <field name="nominee_middle_name_display" string="Middle Name" readonly="1"/>
                                    <field name="nominee_last_name" readonly="1"/>
                                    <field name="nominee_gender" readonly="1"/>
                                    <field name="nominee_zanid" readonly="1"/>
                                    <field name="nominee_rel_benf" readonly="1"/>
                                </group>
                                <group string="Phone Numbers">
                                    <field name="nominee_mobile" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="nominee_house_street" readonly="1"/>
                                    <field name="nominee_shehia" readonly="1"/>
                                    <field name="nominee_post_code_display" readonly="1"/>
                                    <field name="nominee_region_display" readonly="1"/>
                                    <field name="nominee_district_display" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="IDs" name="ids_info">
                            <group>
                                <group>
                                    <field name="id_type_1" string="ID Type" readonly="1"/>
                                    <field name="id_number_1" string="ID Number" readonly="1"/>
                                </group>
                                <group>
                                    <field name="id_type_2" string="ID Type" readonly="1"/>
                                    <field name="id_number_2" string="ID Number" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Payment Mode" name="payment_mode_info">
                            <group>
                                <group>
                                    <field name="payment_mode" readonly="1"/>
                                    <field name="mobile_wallet" readonly="1" invisible="payment_mode != 'mobile_wallet'" />
                                    <field name="bank_name" readonly="1" invisible="payment_mode not in ['bank', 'bank_transfer']" />
                                    <field name="account_num" readonly="1" invisible="payment_mode not in ['bank', 'bank_transfer']" />
                                    <field name="account_name" readonly="1" invisible="payment_mode not in ['bank', 'bank_transfer']" />
                                </group>
                            </group>
                        </page>
                        <page string="Pension Information" name="pension_info">
                            <group>
                                <group>
                                    <field name="other_pension" readonly="1"/>
                                    <field name="scheme_name" readonly="1" invisible="other_pension != 'yes'" />
                                </group>
                            </group>
                        </page>
                        <page string="Additional Information" name="additional_info_tab">
                            <group>
                                <group>
                                    <field name="has_disability" widget="radio" options="{'horizontal': true}" readonly="1"/>
                                    <field name="receives_allowance" widget="radio" options="{'horizontal': true}" readonly="1"/>
                                    <field name="has_health_insurance" widget="radio" options="{'horizontal': true}" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Other Information" name="other_info">
                            <group>
                                <group string="Enumerator Details">
                                    <field name="enumerator_name" />
                                    <field name="enumerator_eid" />
                                    <field name="registration_date" readonly="1" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </xpath>
            
        </field>
    </record>

    <!-- Override validation form wizard: hide Submit, add Reject -->
    <record id="view_validation_form_inherit" model="ir.ui.view">
        <field name="name">validation.form.inherit.zanzibar</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_draft_publish.g2p_validation_form_view" />
        <field name="arch" type="xml">
            <!-- Hide Submit button -->
            <xpath expr="//footer/button[@name='action_submit']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Add Reject button after Approve -->
            <xpath expr="//footer/button[@name='action_publish']" position="after">
                <button
                    class="btn btn-danger"
                    name="action_reject"
                    string="Reject"
                    type="object"
                    invisible="imported_record_state != 'draft'"
                    groups="g2p_draft_publish.group_int_approver,g2p_draft_publish.group_int_admin"
                />
            </xpath>
        </field>
    </record>

    <record id="g2p_validation_form_view_only" model="ir.ui.view">
        <field name="name">Validation Form View Only</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_draft_publish.g2p_validation_form_view_only" />
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="edit">0</attribute>
                <attribute name="create">0</attribute>
            </xpath>
            <!-- Force readonly on Zanzibar specific/custom fields and name fields -->
            <xpath expr="//field[@name='given_name']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='family_name']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='middle_name']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='middle_name']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
             <xpath expr="//field[@name='beneficiary_phone_number_ids']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//field[@name='reg_ids']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <!-- Check if birthdate exists in this view context; it's usually birthdate in registry -->
            <xpath expr="//field[@name='birthdate']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Read-only draft.record form view with chatter -->
    <record id="view_draft_record_readonly_form" model="ir.ui.view">
        <field name="name">draft.record.readonly.form</field>
        <field name="model">draft.record</field>
        <field name="arch" type="xml">
            <form string="Draft Record" edit="0" create="0" delete="0">
                <header>
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,published"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Registrant Name" required="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="given_name" readonly="1"/>
                            <field name="middle_name" readonly="1"/>
                            <field name="family_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="zan_id" readonly="1"/>
                            <field name="birthdate_date" string="Date of Birth" readonly="1"/>
                            <field name="registration_date" readonly="1"/>
                            <field name="gender" readonly="1"/>
                            <field name="phone" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Personal Info" name="personal_info">
                            <group>
                                <group>
                                    <field name="address_display" string="Address" invisible="not address_display" />
                                    <field name="post_code" string="Post Code" invisible="not post_code" />
                                    <field name="region_id" string="Region" invisible="not region_id" />
                                    <field name="district_id" invisible="not district_id" />
                                    <field name="birthdate_date" string="Date of Birth" invisible="not birthdate_date" />
                                    <field name="age" invisible="not age" />
                                    <field name="gender" invisible="not gender" />
                                </group>
                                <group>
                                    <group string="Additional Information" invisible="not has_disability and not receives_allowance and not has_health_insurance">
                                        <field name="has_disability" widget="radio" options="{'horizontal': true}" invisible="not has_disability"/>
                                        <field name="receives_allowance" widget="radio" options="{'horizontal': true}" invisible="not receives_allowance"/>
                                        <field name="has_health_insurance" widget="radio" options="{'horizontal': true}" invisible="not has_health_insurance"/>
                                    </group>
                                </group>
                            </group>
                            <group string="Rejection Details" invisible="state != 'rejected'">
                                <field name="rejection_reason" />
                                <field name="rejected_by_user_id" />
                            </group>
                        </page>
                        <page string="Nominee Info" name="nominee_info" invisible="not nominee_first_name and not nominee_mobile">
                            <group>
                                <group>
                                    <field name="nominee_first_name" invisible="not nominee_first_name" />
                                    <field name="nominee_middle_name_display" string="Middle Name" invisible="not nominee_middle_name_display" />
                                    <field name="nominee_last_name" invisible="not nominee_last_name" />
                                    <field name="nominee_gender" invisible="not nominee_gender" />
                                    <field name="nominee_zanid" invisible="not nominee_zanid" />
                                    <field name="nominee_rel_benf" invisible="not nominee_rel_benf" />
                                </group>
                                <group string="Phone Numbers" invisible="not nominee_mobile">
                                    <field name="nominee_mobile" />
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="nominee_house_street" invisible="not nominee_house_street" />
                                    <field name="nominee_shehia" invisible="not nominee_shehia" />
                                    <field name="nominee_post_code_display" invisible="not nominee_post_code_display" />
                                    <field name="nominee_region_display" invisible="not nominee_region_display" />
                                    <field name="nominee_district_display" invisible="not nominee_district_display" />
                                </group>
                            </group>
                        </page>
                        <page string="IDs" name="ids_info" invisible="not id_number_1 and not id_number_2">
                            <group>
                                <group>
                                    <field name="id_type_1" string="ID Type" invisible="not id_number_1" />
                                    <field name="id_number_1" string="ID Number" invisible="not id_number_1" />
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="id_type_2" string="ID Type" invisible="not id_number_2" />
                                    <field name="id_number_2" string="ID Number" invisible="not id_number_2" />
                                </group>
                            </group>
                        </page>
                        <page string="Payment Mode" name="payment_mode_info" invisible="not payment_mode">
                            <group>
                                <group>
                                    <field name="payment_mode" string="Preferred Payment Method" />
                                    <field name="mobile_wallet" invisible="payment_mode != 'mobile_wallet'" />
                                    <field name="bank_name" invisible="payment_mode not in ['bank', 'bank_transfer']" />
                                    <field name="account_num" string="Account Number" invisible="payment_mode not in ['bank', 'bank_transfer']" />
                                    <field name="account_name" invisible="payment_mode not in ['bank', 'bank_transfer']" />
                                </group>
                            </group>
                        </page>
                        <page string="Pension Information" name="pension_info" invisible="not other_pension">
                            <group>
                                <group>
                                    <field name="other_pension" />
                                    <field name="scheme_name" invisible="other_pension != 'yes'" />
                                </group>
                            </group>
                        </page>
                        <page string="Other Information" name="other_info" invisible="not registration_date and not enumerator_name">
                            <group>
                                <group string="Enumerator Details" invisible="not enumerator_name">
                                    <field name="enumerator_name" />
                                    <field name="enumerator_eid" />
                                    <field name="registration_date" invisible="not registration_date" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search view for Drafts tab -->
    <record id="view_draft_record_search" model="ir.ui.view">
        <field name="name">draft.record.search</field>
        <field name="model">draft.record</field>
        <field name="arch" type="xml">
            <search string="Search Drafts">
                <field name="zan_id" string="Zan ID" />
                <field name="name" string="Name" />
                <field name="phone" string="Phone" />
                <field name="gender" string="Gender" />
                <field name="birthdate_date" string="Date of Birth" />
                <field name="registration_date" string="Registration Date" />
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]" />
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'published')]" />
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" context="{'group_by': 'state'}" />
                    <filter name="group_gender" string="Gender" context="{'group_by': 'gender'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Search view for Rejected tab -->
    <record id="view_rejected_record_search" model="ir.ui.view">
        <field name="name">draft.record.rejected.search</field>
        <field name="model">draft.record</field>
        <field name="arch" type="xml">
            <search string="Search Rejected">
                <field name="zan_id" string="Zan ID" />
                <field name="name" string="Name" />
                <field name="birthdate_date" string="Date of Birth" />
                <field name="rejection_reason" string="Remark" />
                <field name="rejected_by_user_id" string="Rejected By" />
                <group expand="0" string="Group By">
                    <filter name="group_rejected_by" string="Rejected By" context="{'group_by': 'rejected_by_user_id'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- Override Drafts action to show draft + approved records only -->
    <record id="g2p_draft_publish.action_draft_imported_record" model="ir.actions.act_window">
        <field name="name">Draft/Approved</field>
        <field name="res_model">draft.record</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', 'in', ['draft', 'published'])]</field>
        <field name="search_view_id" ref="view_draft_record_search" />
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0,0,{'view_mode': 'tree', 'view_id': ref('g2p_draft_publish.view_draft_imported_record_tree')}),
                (0,0,{'view_mode': 'form', 'view_id': ref('view_draft_record_readonly_form')})]"
        />
    </record>

    <!-- Rejected tree view (shows rejection reason and rejected by) -->
    <record id="view_rejected_record_tree" model="ir.ui.view">
        <field name="name">draft.record.rejected.tree</field>
        <field name="model">draft.record</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" edit="0" import="0">
                <field name="zan_id" />
                <field name="name" />
                <field name="birthdate_date" />
                <field
                    decoration-danger="state == 'rejected'"
                    widget="badge"
                    name="state"
                    class="text-start"
                />
                <field name="rejection_reason" string="Remark" />
                <field name="rejected_by_user_id" />
                <button
                    string="View"
                    type="object"
                    name="action_open_wizard_view_only"
                />
            </tree>
        </field>
    </record>

    <!-- Rejected action -->
    <record id="action_rejected_records" model="ir.actions.act_window">
        <field name="name">Rejected</field>
        <field name="res_model">draft.record</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'rejected')]</field>
        <field name="search_view_id" ref="view_rejected_record_search" />
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0,0,{'view_mode': 'tree', 'view_id': ref('view_rejected_record_tree')}),
                (0,0,{'view_mode': 'form', 'view_id': ref('view_draft_record_readonly_form')})]"
        />
        <field name="context">{'create': False}</field>
    </record>

    <!-- Add Discard button to rejection wizard -->
    <record id="reject_wizard_view_inherit" model="ir.ui.view">
        <field name="name">reject.wizard.form.inherit.zanzibar</field>
        <field name="model">reject.wizard</field>
        <field name="inherit_id" ref="g2p_draft_publish.reject_wizard_view" />
        <field name="arch" type="xml">
            <xpath expr="//footer/button[@name='confirm_rejection']" position="after">
                <button string="Discard" class="btn btn-secondary" special="cancel" />
            </xpath>
        </field>
    </record>

    <!-- Hide "Submitted" menu -->
    <record id="g2p_draft_publish.menu_submitted_records" model="ir.ui.menu">
        <field name="active" eval="False" />
    </record>

    <!-- Add "Rejected" menu -->
    <menuitem
        id="menu_rejected_records"
        name="Rejected"
        parent="g2p_draft_publish.draft_publish_main_menu"
        action="action_rejected_records"
        sequence="12"
    />
</odoo>
