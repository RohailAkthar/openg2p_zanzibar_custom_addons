<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

	<t t-name="zanzi_theme._nsr.AppsMenu" t-inherit="web.Dropdown" t-inherit-mode="primary">
		<xpath expr="//div[@t-ref='menuRef']" position="attributes">
			<attribute name="t-attf-style">
	        	background-image: url("{{ backgroundImageUrl }}");
		    </attribute>
	    </xpath>





	<xpath expr="//div[@t-ref='menuRef']" position="inside">
			<div
                class="added_banner"
                style="z-index: 999;    font-family: 'Roboto', sans-serif !important; position: absolute; top: 20px; width:100%;  margin: 0 auto;"
            >

				<div style="width: 100% !important;padding: 0px 2%;" class="d-flex flex-column ">


<div class="d-flex flex-row justify-content-between ">


					<div class="top_nsr_text d-flex flex-column py-2">
						<h2 style="font-weight:bold; font-family: 'Roboto', sans-serif !important;  color:#0044B2;">Welcome to</h2>
						<h1 style="color: rgba(0,0,0,0.7); font-family: 'Roboto', sans-serif !important; font-weight: lighter;"
                            >Zanzibar Pension Registry</h1>
					</div>

			<div style="    display: grid !important;
    justify-items: end !important;">

			<img
                                class="nsr_img"
                                src="/zanzi_theme/static/src/img/zanzilogo.png"
                                style="width: 100px ;"
                            />
					</div>



					</div>

					<div class="nsr_image_container contimgbackground"  >
						<img
                            class="nsr_img"
                            t-attf-src="{{bannerBackgroundImageUrl}}"
                            style="width: 100%;"
                        />

					<div
                            class="centr_image_container"
                            style=" width:100%; position: absolute; top: 37%; left: 0%; display: flex; flex-direction: column; justify-content: center; align-items: center;"
                        >
    <img class="nsr_star_img" src="/zanzi_theme/static/src/img/egov.png"  style="width: 120px;"/>
    <h3
                                style="padding-top: 10px; font-family: 'Roboto', sans-serif !important;"
                            >Zanzibar Pension Registry</h3>

    <button
                                style="padding: 8px 24px;

    background: rgba(0, 68, 178, 0.2);
    margin-top: 10px;
    color: rgb(0 68 178);
    border-radius: 4px;
    border: transparent; font-family: 'Roboto', sans-serif !important;"
                            >View More</button>
</div>


					</div>
				</div>

			</div>
</xpath>





	</t>

</templates>
