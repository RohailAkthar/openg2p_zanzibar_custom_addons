<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Move groups to Hidden category to ensure they are not displayed in the User form -->
        <record id="account.group_account_invoice" model="res.groups">
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="account.group_account_manager" model="res.groups">
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="account.group_validate_bank_account" model="res.groups">
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="g2p_odk_importer.group_g2p_odk" model="res.groups">
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="queue_job.group_queue_job_manager" model="res.groups">
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <!-- Keep categories invisible just in case -->
        <record model="ir.module.category" id="base.module_category_accounting">
            <field name="visible" eval="0"/>
        </record>

        <record model="ir.module.category" id="base.module_category_accounting_accounting">
            <field name="visible" eval="0"/>
        </record>

        <record model="ir.module.category" id="account.module_category_accounting_bank">
            <field name="visible" eval="0"/>
        </record>

        <record model="ir.module.category" id="g2p_odk_importer.g2p_odk_config">
            <field name="visible" eval="0"/>
        </record>

        <record model="ir.module.category" id="queue_job.module_category_queue_job">
            <field name="visible" eval="0"/>
        </record>

        <!-- Make specific categories visible in normal mode -->
        <record id="g2p_registry_base.openg2p_module" model="ir.module.category">
            <field name="visible" eval="1"/>
        </record>

        <record id="g2p_documents.g2p_documents_module" model="ir.module.category">
            <field name="visible" eval="1"/>
        </record>

        <!-- Hide specific groups from the user form -->
        <record id="g2p_registry_base.group_g2p_restrict_access_to_self" model="res.groups">
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>
    </data>
</odoo>
